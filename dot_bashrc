test -f "$HOME/.profile" && . "$HOME/.profile"

test -f "/usr/share/ghostty/shell-integration/bash/ghostty.bash" && . "/usr/share/ghostty/shell-integration/bash/ghostty.bash"
test -f "/home/linuxbrew/.linuxbrew/bin/brew" && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
type "mise" &>/dev/null && eval "$(mise activate bash)"

if type brew &>/dev/null; then
    HOMEBREW_PREFIX="$(brew --prefix)"
    if [[ -r "${HOMEBREW_PREFIX}/etc/profile.d/bash_completion.sh" ]]; then
        source "${HOMEBREW_PREFIX}/etc/profile.d/bash_completion.sh"
    else
        for COMPLETION in "${HOMEBREW_PREFIX}/etc/bash_completion.d/"*; do
              [[ -r "${COMPLETION}" ]] && source "${COMPLETION}"
        done
    fi
fi

